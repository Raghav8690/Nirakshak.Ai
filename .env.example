# ===========================
# Nirikshak.AI — Environment Variables
# ===========================
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control.

# ===========================
# Database
# ===========================
# For local dev (SQLite — no setup needed):
DATABASE_URL=sqlite:///./nirikshak.db

# For Docker/production (PostgreSQL):
# DATABASE_URL=postgresql://nirikshak:nirikshak_pass@postgres:5432/nirikshak_db

# ===========================
# LLM Provider (Optional — app works fully without this)
# ===========================
# Supported: "mock" (default, no API key needed), "openai", "claude"
LLM_PROVIDER=mock
LLM_API_KEY=your_api_key_here

# ===========================
# ChromaDB (Vector Database)
# ===========================
CHROMA_PERSIST_DIR=./chroma_data

# ===========================
# App Settings
# ===========================
DEBUG=true
BACKEND_PORT=8000
FRONTEND_PORT=5173
SECRET_KEY=change_this_to_a_random_secret_string

# ===========================
# CORS (Frontend URL)
# ===========================
FRONTEND_URL=http://localhost:5173
